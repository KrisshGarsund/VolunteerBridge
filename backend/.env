# VolunteerBridge Environment Configuration
# ---- Separate Databases for Each Portal ----
MONGO_URI_ADMIN=mongodb://localhost:27017/volunteerbridge_admin
MONGO_URI_VOLUNTEER=mongodb://localhost:27017/volunteerbridge_volunteer
MONGO_URI_NGO=mongodb://localhost:27017/volunteerbridge_ngo

# ---- Legacy single DB (kept for reference) ----
MONGO_URI=mongodb://localhost:27017/volunteerbridge

# ---- JWT ----
JWT_SECRET_KEY=volunteerbridge-super-secret-key-change-in-production

# ---- Flask ----
FLASK_ENV=development
FLASK_DEBUG=True

# ---- Ports ----
ADMIN_PORT=5001
VOLUNTEER_PORT=5002
NGO_PORT=5003
